# ── Stage 1: finding jobs (Anthropic API) ──
ANTHROPIC_API_KEY=sk-ant-...

# ── Stage 2: saving to Design Tokri (Supabase / Lovable backend) ──
# Find these in the Supabase dashboard → Project Settings → API,
# or in Lovable's Cloud/Backend settings if you use Lovable Cloud.
SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_SERVICE_KEY=eyJ...        # service_role key — server-only, keep secret
JOBS_TABLE=jobs                    # your table name
AUTO_PUBLISH=false                 # false = land as "pending" for your review

# ── Stage 3: posting to LinkedIn (official Posts API) ──
POST_TO_LINKEDIN=false             # flip to true once LinkedIn access is approved
LINKEDIN_ACCESS_TOKEN=...
LINKEDIN_ORG_URN=urn:li:organization:1234567
LINKEDIN_VERSION=202605            # set to the current YYYYMM when you build
